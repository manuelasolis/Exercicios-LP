#include <stdio.h>

int main(){
    int N;

    printf("Digite o valor de N (entre 1 e 10): ");
    scanf("%d", &N);

    while(N < 1 || N > 10){
        printf("Digite um valor entre 1 e 10: ");
        scanf("%d", &N);
    }

    for(int i = 1; i <= 10; i++){
        printf("%d x %d = %d\n", N, i, N * i);
    }
}
