#include <stdio.h>

int main(){
    int valor, dentro = 0, fora = 0;

    for(int i = 1; i <= 10; i++){
        printf("Digite um valor: ");
        scanf("%d", &valor);

        if(valor >= 10 && valor <= 20){
            dentro++;
        } else {
            fora++;
        }
    }

    printf("Dentro do intervalo: %d\n", dentro);
    printf("Fora do intervalo: %d\n", fora);
}
